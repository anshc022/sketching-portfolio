---
import Base from '../layouts/Base.astro';

// Placeholder gallery data — will be replaced with Instagram API data
const artworks = [
  { title: "Portrait Study I", medium: "Graphite on 200gsm", aspect: "3/4" },
  { title: "Floral Sketch", medium: "Pencil on paper", aspect: "1/1" },
  { title: "Eye Detail", medium: "Charcoal", aspect: "4/3" },
  { title: "Landscape", medium: "Graphite", aspect: "16/9" },
  { title: "Portrait Study II", medium: "Charcoal on textured paper", aspect: "3/4" },
  { title: "Animal Sketch", medium: "Pencil", aspect: "1/1" },
  { title: "Hand Study", medium: "Graphite on 200gsm", aspect: "3/4" },
  { title: "Architecture", medium: "Ink and pencil", aspect: "4/3" },
  { title: "Portrait Study III", medium: "Charcoal", aspect: "3/4" },
];

const categories = ["All", "Portraits", "Nature", "Charcoal", "Pencil"];
---
<Base title="Gallery" description="Browse the complete collection of sketches and illustrations.">
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <p class="text-gold text-sm font-body font-medium tracking-[0.3em] uppercase mb-2">The Collection</p>
      <h1 class="font-heading text-4xl md:text-5xl text-charcoal mb-4">Gallery</h1>
      <p class="text-charcoal/60 font-body max-w-xl mx-auto">Each piece is a journey from blank paper to finished art. Click on any piece to view it in full detail.</p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap justify-center gap-3 mb-10">
      {categories.map((cat, i) => (
        <button class={`px-4 py-2 rounded-full font-body text-sm font-medium transition-all ${i === 0 ? 'bg-charcoal text-parchment' : 'bg-parchment-dark text-charcoal hover:bg-charcoal hover:text-parchment'}`}>
          {cat}
        </button>
      ))}
    </div>

    <!-- Masonry Grid -->
    <div class="masonry-grid">
      {artworks.map((art) => (
        <div class="masonry-item">
          <div class="gallery-card cursor-pointer" data-lightbox>
            <div class={`bg-parchment-dark flex items-center justify-center`} style={`aspect-ratio: ${art.aspect};`}>
              <div class="text-center p-6">
                <svg class="w-12 h-12 mx-auto text-charcoal/15 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p class="text-charcoal/30 font-body text-xs">{art.title}</p>
              </div>
            </div>
            <div class="overlay">
              <div>
                <p class="text-parchment font-heading text-lg">{art.title}</p>
                <p class="text-parchment/70 font-body text-sm">{art.medium}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox-overlay" onclick="this.classList.remove('active')">
    <img src="" alt="Full view" />
  </div>
</Base>
