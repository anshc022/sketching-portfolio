---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Gallery | Sketching with Heart">
	<Nav />
	<main class="max-w-6xl mx-auto px-6 py-16">
		<header class="text-center mb-16">
			<h1 class="text-5xl font-['Cormorant_Garamond'] font-semibold mb-4">Gallery</h1>
			<p class="text-black/50 text-sm uppercase tracking-widest">A collection of pencil, graphite & charcoal work</p>
		</header>

		<div class="flex justify-center gap-4 mb-12">
			<button class="filter-btn active uppercase text-xs tracking-[0.2em] px-4 py-2 border border-[#8B735B]/30 text-[#8B735B] bg-[#8B735B]/10" data-filter="all">All</button>
			<button class="filter-btn uppercase text-xs tracking-[0.2em] px-4 py-2 border border-black/10 text-black/40 hover:text-[#8B735B] hover:border-[#8B735B]/30 transition-colors" data-filter="portrait">Portraits</button>
			<button class="filter-btn uppercase text-xs tracking-[0.2em] px-4 py-2 border border-black/10 text-black/40 hover:text-[#8B735B] hover:border-[#8B735B]/30 transition-colors" data-filter="landscape">Landscapes</button>
			<button class="filter-btn uppercase text-xs tracking-[0.2em] px-4 py-2 border border-black/10 text-black/40 hover:text-[#8B735B] hover:border-[#8B735B]/30 transition-colors" data-filter="illustration">Illustrations</button>
		</div>

		<div id="gallery-grid" class="columns-1 md:columns-2 lg:columns-3 gap-8">
			<!-- Will be populated by IG Basic Display API -->
			{Array.from({ length: 9 }).map((_, i) => (
				<div class="break-inside-avoid mb-8 rounded-sm shadow-xl shadow-black/5 overflow-hidden group bg-white p-2">
					<div class:list={[
						'bg-gradient-to-b from-gray-50 to-gray-100 flex items-center justify-center',
						i % 3 === 0 ? 'aspect-[4/5]' : i % 3 === 1 ? 'aspect-square' : 'aspect-[3/4]'
					]}>
						<p class="text-black/20 text-xs uppercase tracking-widest">Sketch {i + 1}</p>
					</div>
				</div>
			))}
		</div>
	</main>
	<Footer />
</Layout>

<script>
	document.querySelectorAll('.filter-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			document.querySelectorAll('.filter-btn').forEach(b => {
				b.classList.remove('active', 'bg-[#8B735B]/10', 'text-[#8B735B]', 'border-[#8B735B]/30');
				b.classList.add('text-black/40', 'border-black/10');
			});
			btn.classList.add('active', 'bg-[#8B735B]/10', 'text-[#8B735B]', 'border-[#8B735B]/30');
			btn.classList.remove('text-black/40', 'border-black/10');
			// Filter logic will hook into IG feed data
		});
	});
</script>
