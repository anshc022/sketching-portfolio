---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Commission | Sketching with Heart">
	<Nav />
	<main class="max-w-4xl mx-auto px-6 py-16">
		<header class="text-center mb-16">
			<h1 class="text-5xl font-['Cormorant_Garamond'] font-semibold mb-4">Commission a Piece</h1>
			<p class="text-black/50 text-sm max-w-lg mx-auto leading-relaxed">
				Want a custom portrait, pet sketch, or illustration? Fill out the form below
				and I'll get back to you with details and pricing.
			</p>
		</header>

		<div class="grid md:grid-cols-5 gap-16">
			<div class="md:col-span-3">
				<form id="commission-form" class="space-y-6">
					<div>
						<label class="block text-xs uppercase tracking-widest text-black/40 mb-2">Your Name</label>
						<input type="text" name="name" required
							class="w-full bg-white border border-black/10 px-4 py-3 text-sm focus:outline-none focus:border-[#8B735B] transition-colors" />
					</div>

					<div>
						<label class="block text-xs uppercase tracking-widest text-black/40 mb-2">Email</label>
						<input type="email" name="email" required
							class="w-full bg-white border border-black/10 px-4 py-3 text-sm focus:outline-none focus:border-[#8B735B] transition-colors" />
					</div>

					<div>
						<label class="block text-xs uppercase tracking-widest text-black/40 mb-2">Phone (Optional)</label>
						<input type="tel" name="phone"
							class="w-full bg-white border border-black/10 px-4 py-3 text-sm focus:outline-none focus:border-[#8B735B] transition-colors" />
					</div>

					<div class="grid grid-cols-2 gap-4">
						<div>
							<label class="block text-xs uppercase tracking-widest text-black/40 mb-2">Size</label>
							<select name="size"
								class="w-full bg-white border border-black/10 px-4 py-3 text-sm focus:outline-none focus:border-[#8B735B] transition-colors">
								<option value="a5">A5 (Small)</option>
								<option value="a4" selected>A4 (Standard)</option>
								<option value="a3">A3 (Large)</option>
								<option value="custom">Custom Size</option>
							</select>
						</div>
						<div>
							<label class="block text-xs uppercase tracking-widest text-black/40 mb-2">Medium</label>
							<select name="medium"
								class="w-full bg-white border border-black/10 px-4 py-3 text-sm focus:outline-none focus:border-[#8B735B] transition-colors">
								<option value="graphite" selected>Graphite Pencil</option>
								<option value="charcoal">Charcoal</option>
								<option value="mixed">Mixed Media</option>
							</select>
						</div>
					</div>

					<div>
						<label class="block text-xs uppercase tracking-widest text-black/40 mb-2">Reference Photo</label>
						<div class="border border-dashed border-black/20 p-8 text-center bg-white cursor-pointer hover:border-[#8B735B] transition-colors">
							<input type="file" name="reference" accept="image/*" class="hidden" id="file-input" />
							<label for="file-input" class="cursor-pointer">
								<p class="text-black/30 text-xs uppercase tracking-widest">Click to upload reference image</p>
								<p class="text-black/20 text-xs mt-1">JPG, PNG up to 10MB</p>
							</label>
						</div>
					</div>

					<div>
						<label class="block text-xs uppercase tracking-widest text-black/40 mb-2">Details</label>
						<textarea name="details" rows="4"
							placeholder="Tell me about what you'd like..."
							class="w-full bg-white border border-black/10 px-4 py-3 text-sm focus:outline-none focus:border-[#8B735B] transition-colors resize-none"></textarea>
					</div>

					<button type="submit"
						class="w-full uppercase text-xs tracking-[0.2em] bg-[#333] text-[#F5F2ED] px-8 py-4 hover:bg-[#8B735B] transition-all duration-300">
						Submit Request
					</button>
				</form>
			</div>

			<div class="md:col-span-2">
				<div class="sticky top-24 space-y-8">
					<div>
						<h3 class="font-['Cormorant_Garamond'] text-xl mb-4">Pricing Guide</h3>
						<div class="space-y-3 text-sm text-black/60">
							<div class="flex justify-between border-b border-black/5 pb-2">
								<span>A5 Graphite</span>
								<span class="text-[#8B735B]">Contact for price</span>
							</div>
							<div class="flex justify-between border-b border-black/5 pb-2">
								<span>A4 Graphite</span>
								<span class="text-[#8B735B]">Contact for price</span>
							</div>
							<div class="flex justify-between border-b border-black/5 pb-2">
								<span>A3 Graphite</span>
								<span class="text-[#8B735B]">Contact for price</span>
							</div>
							<div class="flex justify-between pb-2">
								<span>Charcoal</span>
								<span class="text-[#8B735B]">Contact for price</span>
							</div>
						</div>
					</div>

					<div>
						<h3 class="font-['Cormorant_Garamond'] text-xl mb-4">Timeline</h3>
						<p class="text-sm text-black/50 leading-relaxed">
							Most commissions take 1-3 weeks depending on size and complexity.
							Rush orders may be available upon request.
						</p>
					</div>

					<div>
						<h3 class="font-['Cormorant_Garamond'] text-xl mb-4">What to Expect</h3>
						<ol class="space-y-2 text-sm text-black/50">
							<li class="flex gap-3">
								<span class="text-[#8B735B] font-['Cormorant_Garamond']">1.</span>
								Submit your request
							</li>
							<li class="flex gap-3">
								<span class="text-[#8B735B] font-['Cormorant_Garamond']">2.</span>
								Receive a quote within 48 hours
							</li>
							<li class="flex gap-3">
								<span class="text-[#8B735B] font-['Cormorant_Garamond']">3.</span>
								Progress updates with WIP photos
							</li>
							<li class="flex gap-3">
								<span class="text-[#8B735B] font-['Cormorant_Garamond']">4.</span>
								Final delivery (digital + physical)
							</li>
						</ol>
					</div>
				</div>
			</div>
		</div>
	</main>
	<Footer />
</Layout>
