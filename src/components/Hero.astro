---
---

<section id="home" class="relative h-screen flex items-center justify-center overflow-hidden">
	<!-- Parallax background -->
	<div class="absolute inset-0 parallax-bg" id="hero-bg">
		<div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/30 via-transparent to-[#0a0a0a]"></div>
		<div class="absolute inset-0 bg-[#0a0a0a]/40"></div>
		<!-- Grid pattern overlay -->
		<div class="absolute inset-0 opacity-[0.03]"
			style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;">
		</div>
	</div>

	<div class="relative z-10 text-center px-6">
		<p class="text-[11px] uppercase tracking-[0.5em] text-white/40 mb-8 animate-fade-up">Portfolio</p>
		<h1 class="text-6xl md:text-8xl lg:text-9xl font-bold leading-[0.9] mb-6">
			<span class="block opacity-0 animate-title-1">Sketching</span>
			<span class="block text-white/30 opacity-0 animate-title-2">with</span>
			<span class="block opacity-0 animate-title-3">Heart</span>
		</h1>
		<p class="text-white/30 text-sm tracking-wider mt-8 max-w-md mx-auto opacity-0 animate-subtitle">
			Graphite & Charcoal Art by Varsha
		</p>

		<div class="mt-16 opacity-0 animate-scroll-hint">
			<div class="w-[1px] h-16 bg-gradient-to-b from-transparent via-white/30 to-transparent mx-auto"></div>
			<p class="text-[10px] uppercase tracking-[0.4em] text-white/20 mt-4">Scroll</p>
		</div>
	</div>
</section>

<style>
	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(30px); }
		to { opacity: 1; transform: translateY(0); }
	}
	@keyframes titleReveal {
		from { opacity: 0; transform: translateY(60px) skewY(3deg); }
		to { opacity: 1; transform: translateY(0) skewY(0); }
	}

	.animate-fade-up { animation: fadeUp 1s ease-out 0.2s forwards; }
	.animate-title-1 { animation: titleReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards; }
	.animate-title-2 { animation: titleReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards; }
	.animate-title-3 { animation: titleReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards; }
	.animate-subtitle { animation: fadeUp 1s ease-out 1.2s forwards; }
	.animate-scroll-hint { animation: fadeUp 1s ease-out 1.8s forwards; }
</style>

<script>
	const heroBg = document.getElementById('hero-bg');
	window.addEventListener('scroll', () => {
		if (heroBg) {
			const scroll = window.scrollY;
			heroBg.style.transform = `translateY(${scroll * 0.4}px)`;
		}
	});
</script>
