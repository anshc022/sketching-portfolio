---
const steps = [
	{ step: '01', title: 'Share Your Vision', desc: 'Send me your reference photos and tell me what makes this piece special to you. Every detail matters — the lighting, the emotion, the story.', image: '/artworks/process_01_vision.png' },
	{ step: '02', title: 'Rough Composition', desc: 'I create initial thumbnail sketches exploring different compositions. We pick the one that captures the essence of your vision.', image: '/artworks/process_02_composition.png' },
	{ step: '03', title: 'Detailed Underlay', desc: 'Light guidelines map out proportions and placement. This invisible framework is what separates good art from great art.', image: '/artworks/process_03_underlay.png' },
	{ step: '04', title: 'Layer by Layer', desc: 'Building depth through progressive layering — light tones first, then mid-tones, finally the rich darks that bring everything to life.', image: '/artworks/process_04_layering.png' },
	{ step: '05', title: 'Final Details', desc: "The magic stage. Highlights, texture refinements, and those tiny details that make people say \"wait, that's a drawing?\"", image: '/artworks/process_05_details.png' },
	{ step: '06', title: 'Delivered to You', desc: 'Your finished piece, carefully packaged with a high-res digital scan. Ready to frame, gift, or admire forever.', image: '/artworks/process_06_delivered.png' },
];
---

<section class="relative py-20 md:py-32 overflow-hidden">
	<div class="max-w-[1100px] mx-auto px-4 md:px-8">
		<div class="reveal text-center mb-12 md:mb-20">
			<p class="text-[11px] uppercase tracking-[0.5em] text-amber-600/50 dark:text-amber-400/40 mb-4">How It Works</p>
			<h2 class="text-4xl md:text-6xl font-bold">Creative Journey</h2>
		</div>

		<!-- MOBILE LAYOUT: vertical cards with left timeline line -->
		<div class="md:hidden relative">
			<!-- Vertical line -->
			<div class="absolute left-5 top-0 bottom-0 w-[1px] bg-gradient-to-b from-amber-500/20 via-amber-500/10 to-transparent dark:from-amber-400/15 dark:via-amber-400/8"></div>

			<div class="space-y-6">
				{steps.map((s, i) => (
					<div class={`reveal reveal-delay-${Math.min(i + 1, 4)} relative pl-14`}>
						<!-- Number circle on the line -->
						<div class="absolute left-0 top-3 w-10 h-10 rounded-full border-2 border-amber-500/20 dark:border-amber-400/15 bg-[#faf9f6] dark:bg-[#0a0a0a] flex items-center justify-center z-10">
							<span class="text-[10px] font-['Space_Mono',monospace] text-amber-600/50 dark:text-amber-400/40">{s.step}</span>
						</div>

						<!-- Card -->
						<div class="bg-[#f0efe9] dark:bg-[#141414] rounded-2xl overflow-hidden border border-[#1a1a1a]/[0.06] dark:border-white/[0.04] shadow-sm">
							<!-- Image -->
							<div class="aspect-[16/9] overflow-hidden">
								<img src={s.image} alt={s.title} class="w-full h-full object-cover" loading="lazy" />
							</div>
							<!-- Text -->
							<div class="p-4 pb-5">
								<span class="text-[9px] uppercase tracking-[0.3em] text-amber-600/40 dark:text-amber-400/30 mb-1.5 block">Step {s.step}</span>
								<h3 class="text-lg font-['Playfair_Display',serif] font-bold mb-2">{s.title}</h3>
								<p class="text-xs leading-[1.8] text-[#1a1a1a]/40 dark:text-white/30">{s.desc}</p>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>

		<!-- DESKTOP LAYOUT: zigzag timeline -->
		<div class="hidden md:block relative">
			<!-- Center vertical line -->
			<div class="absolute left-1/2 top-0 bottom-0 w-[1px] -translate-x-1/2 bg-gradient-to-b from-amber-500/15 via-[#1a1a1a]/[0.06] dark:via-white/[0.04] to-transparent"></div>

			<div class="space-y-0">
				{steps.map((s, i) => {
					const isEven = i % 2 === 0;
					return (
						<div class={`reveal reveal-delay-${Math.min(i + 1, 4)} relative grid grid-cols-[1fr_60px_1fr] items-center min-h-[280px]`}>
							
							{/* Left column */}
							<div class={isEven ? 'pr-8' : 'order-3 pl-8'}>
								{isEven ? (
									<div class="rounded-2xl overflow-hidden aspect-[16/10] border border-[#1a1a1a]/[0.06] dark:border-white/[0.04] shadow-lg shadow-black/5 dark:shadow-black/20">
										<img src={s.image} alt={s.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
									</div>
								) : (
									<div class="text-right">
										<span class="text-[9px] uppercase tracking-[0.3em] text-amber-600/40 dark:text-amber-400/30 mb-2 block">Step {s.step}</span>
										<h3 class="text-2xl font-['Playfair_Display',serif] font-bold mb-3">{s.title}</h3>
										<p class="text-sm leading-[1.8] text-[#1a1a1a]/35 dark:text-white/30">{s.desc}</p>
									</div>
								)}
							</div>

							{/* Center number */}
							<div class="flex flex-col items-center order-2">
								<div class="w-[1px] flex-1 bg-transparent"></div>
								<div class="w-12 h-12 rounded-full border-2 border-[#1a1a1a]/[0.08] dark:border-white/[0.06] bg-[#faf9f6] dark:bg-[#0a0a0a] flex items-center justify-center my-3 hover:border-amber-500/30 dark:hover:border-amber-400/20 transition-colors duration-500">
									<span class="text-[10px] font-['Space_Mono',monospace] text-[#1a1a1a]/25 dark:text-white/20">{s.step}</span>
								</div>
								<div class="w-[1px] flex-1 bg-transparent"></div>
							</div>

							{/* Right column */}
							<div class={isEven ? '' : 'order-1 pr-8'}>
								{isEven ? (
									<div>
										<span class="text-[9px] uppercase tracking-[0.3em] text-amber-600/40 dark:text-amber-400/30 mb-2 block">Step {s.step}</span>
										<h3 class="text-2xl font-['Playfair_Display',serif] font-bold mb-3">{s.title}</h3>
										<p class="text-sm leading-[1.8] text-[#1a1a1a]/35 dark:text-white/30">{s.desc}</p>
									</div>
								) : (
									<div class="rounded-2xl overflow-hidden aspect-[16/10] border border-[#1a1a1a]/[0.06] dark:border-white/[0.04] shadow-lg shadow-black/5 dark:shadow-black/20">
										<img src={s.image} alt={s.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
									</div>
								)}
							</div>
						</div>
					);
				})}
			</div>
		</div>
	</div>
</section>
