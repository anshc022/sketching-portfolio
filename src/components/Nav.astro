---
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/gallery', label: 'Gallery' },
	{ href: '/about', label: 'About' },
	{ href: '/commission', label: 'Commission' },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-[#F5F2ED]/90 backdrop-blur-sm border-b border-black/5">
	<div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
		<a href="/" class="font-['Cormorant_Garamond'] text-2xl font-semibold tracking-tight text-[#333]">
			S.W.H
		</a>
		<ul class="flex gap-8">
			{navItems.map(item => (
				<li>
					<a
						href={item.href}
						class:list={[
							'uppercase text-xs tracking-[0.2em] transition-colors duration-200',
							currentPath === item.href ? 'text-[#8B735B]' : 'text-[#333]/60 hover:text-[#333]'
						]}
					>
						{item.label}
					</a>
				</li>
			))}
		</ul>
	</div>
</nav>
