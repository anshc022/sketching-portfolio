---
const navItems = [
	{ href: '#home', label: 'Home' },
	{ href: '#gallery', label: 'Gallery' },
	{ href: '#about', label: 'About' },
	{ href: '#commission', label: 'Commission' },
];
---

<!-- Mobile menu overlay — OUTSIDE nav to avoid clipping -->
<div class="fixed inset-0 w-full h-full bg-[#0a0a0a] flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500 md:hidden" id="mobile-menu" style="z-index: 9990;">
	<div class="flex flex-col items-center gap-10">
		{navItems.map((item, i) => (
			<a href={item.href}
				class="mobile-nav-link text-3xl font-['Playfair_Display',serif] text-white/70 hover:text-amber-400 transition-colors tracking-wider"
				style={`transition-delay: ${i * 80}ms;`}>
				{item.label}
			</a>
		))}
	</div>
	<div class="mt-14 flex flex-col items-center gap-5">
		<a href="https://www.instagram.com/sketching_.wid_.heart" target="_blank" rel="noopener"
			class="text-[11px] uppercase tracking-[0.3em] text-amber-400/60 hover:text-amber-400 transition-colors">
			@sketching_.wid_.heart
		</a>
		<a href="https://www.instagram.com/varsha.r_.o" target="_blank" rel="noopener"
			class="text-[11px] uppercase tracking-[0.3em] text-white/30 hover:text-white/60 transition-colors">
			Personal IG
		</a>
	</div>
</div>

<nav class="fixed top-0 left-0 w-full transition-all duration-500" id="navbar" style="z-index: 9995;">
	<div class="max-w-7xl mx-auto px-4 md:px-8 py-4 md:py-6 flex items-center justify-between">
		<a href="#home" class="font-['Playfair_Display',serif] text-lg md:text-xl tracking-wider text-white/90 hover:text-white transition-colors">
			S.W.H
		</a>

		<!-- Desktop nav -->
		<div class="hidden md:flex items-center gap-10">
			{navItems.map(item => (
				<a href={item.href}
					class="text-[11px] uppercase tracking-[0.3em] text-white/50 hover:text-white transition-all duration-300 relative group">
					{item.label}
					<span class="absolute -bottom-1 left-0 w-0 h-[1px] bg-gradient-to-r from-amber-400 to-orange-400 group-hover:w-full transition-all duration-300"></span>
				</a>
			))}
		</div>

		<div class="flex items-center gap-4">
			<a href="https://www.instagram.com/sketching_.wid_.heart" target="_blank" rel="noopener"
				class="hidden md:inline-flex text-[11px] uppercase tracking-[0.3em] text-white/50 hover:text-amber-400 transition-colors">
				IG
			</a>

			<!-- Mobile hamburger -->
			<button class="md:hidden relative w-10 h-10 flex flex-col items-center justify-center gap-[5px]" id="menu-toggle" aria-label="Toggle menu">
				<span class="w-5 h-[1.5px] bg-white/70 transition-all duration-300 origin-center" id="bar1"></span>
				<span class="w-5 h-[1.5px] bg-white/70 transition-all duration-300" id="bar2"></span>
				<span class="w-3.5 h-[1.5px] bg-white/70 transition-all duration-300 origin-center" id="bar3"></span>
			</button>
		</div>
	</div>
</nav>

<script>
	const navbar = document.getElementById('navbar');
	const menuToggle = document.getElementById('menu-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	const bar1 = document.getElementById('bar1');
	const bar2 = document.getElementById('bar2');
	const bar3 = document.getElementById('bar3');
	let menuOpen = false;

	function closeMenu() {
		menuOpen = false;
		if (mobileMenu) {
			mobileMenu.style.opacity = '0';
			mobileMenu.style.pointerEvents = 'none';
		}
		bar1?.classList.remove('rotate-45', 'translate-y-[6.5px]');
		bar2?.classList.remove('opacity-0');
		bar3?.classList.remove('-rotate-45', '-translate-y-[6.5px]', 'w-5');
		document.body.style.overflow = '';
	}

	function openMenu() {
		menuOpen = true;
		if (mobileMenu) {
			mobileMenu.style.opacity = '1';
			mobileMenu.style.pointerEvents = 'auto';
		}
		bar1?.classList.add('rotate-45', 'translate-y-[6.5px]');
		bar2?.classList.add('opacity-0');
		bar3?.classList.add('-rotate-45', '-translate-y-[6.5px]', 'w-5');
		document.body.style.overflow = 'hidden';
	}

	menuToggle?.addEventListener('click', () => {
		menuOpen ? closeMenu() : openMenu();
	});

	// Close menu on nav link click
	document.querySelectorAll('.mobile-nav-link').forEach(link => {
		link.addEventListener('click', closeMenu);
	});

	// Close on escape
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && menuOpen) closeMenu();
	});

	window.addEventListener('scroll', () => {
		if (window.scrollY > 100) {
			navbar?.classList.add('bg-[#0a0a0a]/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
		} else {
			navbar?.classList.remove('bg-[#0a0a0a]/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
		}
	});
</script>
