			class="inline-block text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-['Playfair_Display',serif] font-bold text-white/[0.07] hover:text-amber-400/20 transition-colors duration-500 leading-none cursor-pointer">
			@sketching_.wid_.heart
