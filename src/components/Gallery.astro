---
const sketches = [
	{ id: 1, title: 'Portrait Study', category: 'Portrait', image: '/artworks/sketch_01.png' },
	{ id: 2, title: 'Mountain Serenity', category: 'Landscape', image: '/artworks/sketch_02.png' },
	{ id: 3, title: 'Lotus Bloom', category: 'Detail', image: '/artworks/sketch_03.png' },
	{ id: 4, title: 'Wisdom Lines', category: 'Portrait', image: '/artworks/sketch_04.png' },
	{ id: 5, title: 'Vintage Journey', category: 'Object', image: '/artworks/sketch_05.png' },
	{ id: 6, title: 'Wild Gaze', category: 'Detail', image: '/artworks/sketch_06.png' },
	{ id: 7, title: 'Grace in Motion', category: 'Portrait', image: '/artworks/sketch_07.png' },
	{ id: 8, title: 'Temple Ruins', category: 'Landscape', image: '/artworks/sketch_08.png' },
];
---

<!-- Bento Grid Gallery -->
<section id="gallery" class="relative py-20 md:py-32 px-4 md:px-8 lg:px-12">
	<div class="max-w-[1400px] mx-auto">
		<div class="mb-12 md:mb-16">
			<p class="text-[11px] uppercase tracking-[0.5em] text-white/30 mb-4">Selected Works</p>
			<h2 class="text-4xl md:text-6xl font-bold">Gallery</h2>
		</div>

		<!-- Bento Grid -->
		<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 auto-rows-[140px] sm:auto-rows-[180px] md:auto-rows-[200px] lg:auto-rows-[220px]">
			
			<!-- Card 1: Portrait Study — tall left -->
			<div class="bento-card group row-span-2 col-span-1 md:col-span-2 md:row-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-white/5 cursor-pointer">
				<img src={sketches[0].image} alt={sketches[0].title}
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-4 md:p-6 lg:p-8">
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/40 mb-1">{sketches[0].category}</p>
					<p class="text-base md:text-xl lg:text-2xl font-['Playfair_Display',serif]">{sketches[0].title}</p>
				</div>
				<div class="absolute top-3 right-3 md:top-4 md:right-4 w-8 h-8 md:w-10 md:h-10 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
					<svg class="w-3 h-3 md:w-4 md:h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
				</div>
			</div>

			<!-- Card 2: Mountain Serenity — wide top right -->
			<div class="bento-card group col-span-1 md:col-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-white/5 cursor-pointer">
				<img src={sketches[1].image} alt={sketches[1].title}
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-4 md:p-5">
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/40 mb-1">{sketches[1].category}</p>
					<p class="text-sm md:text-lg font-['Playfair_Display',serif]">{sketches[1].title}</p>
				</div>
			</div>

			<!-- Card 3: Lotus Bloom — small square -->
			<div class="bento-card group relative overflow-hidden rounded-xl md:rounded-2xl bg-white/5 cursor-pointer">
				<img src={sketches[2].image} alt={sketches[2].title}
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-3 md:p-4">
					<p class="text-[9px] uppercase tracking-[0.3em] text-white/40 mb-0.5">{sketches[2].category}</p>
					<p class="text-xs md:text-sm font-['Playfair_Display',serif]">{sketches[2].title}</p>
				</div>
			</div>

			<!-- Card 4: Wisdom Lines — small -->
			<div class="bento-card group relative overflow-hidden rounded-xl md:rounded-2xl bg-white/5 cursor-pointer">
				<img src={sketches[3].image} alt={sketches[3].title}
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-3 md:p-4">
					<p class="text-[9px] uppercase tracking-[0.3em] text-white/40 mb-0.5">{sketches[3].category}</p>
					<p class="text-xs md:text-sm font-['Playfair_Display',serif]">{sketches[3].title}</p>
				</div>
			</div>

			<!-- Stats card — text only, no image -->
			<div class="bento-card col-span-2 md:col-span-1 relative overflow-hidden rounded-xl md:rounded-2xl bg-white/[0.03] border border-white/5 flex flex-col justify-center p-5 md:p-6">
				<p class="text-3xl md:text-4xl font-['Playfair_Display',serif] font-bold mb-1">50+</p>
				<p class="text-[10px] uppercase tracking-[0.3em] text-white/30">Artworks Created</p>
				<div class="absolute top-4 right-4 w-8 h-8 rounded-full border border-white/10 flex items-center justify-center">
					<svg class="w-3 h-3 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
				</div>
			</div>

			<!-- Card 5: Vintage Journey — wide -->
			<div class="bento-card group col-span-2 md:col-span-1 row-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-white/5 cursor-pointer">
				<img src={sketches[4].image} alt={sketches[4].title}
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-4 md:p-5">
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/40 mb-1">{sketches[4].category}</p>
					<p class="text-sm md:text-lg font-['Playfair_Display',serif]">{sketches[4].title}</p>
				</div>
			</div>

			<!-- Card 6: Wild Gaze — medium -->
			<div class="bento-card group col-span-1 md:col-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-white/5 cursor-pointer">
				<img src={sketches[5].image} alt={sketches[5].title}
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-4 md:p-5">
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/40 mb-1">{sketches[5].category}</p>
					<p class="text-sm md:text-lg font-['Playfair_Display',serif]">{sketches[5].title}</p>
				</div>
			</div>

			<!-- CTA card -->
			<div class="bento-card col-span-1 relative overflow-hidden rounded-xl md:rounded-2xl bg-gradient-to-br from-white/[0.06] to-white/[0.02] border border-white/5 flex flex-col justify-center items-center p-5 md:p-6 text-center">
				<p class="text-[10px] md:text-xs uppercase tracking-[0.3em] text-white/30 mb-2">Want one?</p>
				<a href="#commission" class="text-xs md:text-sm text-white/70 hover:text-white transition-colors underline underline-offset-4 decoration-white/20 hover:decoration-white/50">
					Commission a Sketch
				</a>
			</div>

			<!-- Card 7: Grace in Motion — tall -->
			<div class="bento-card group row-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-white/5 cursor-pointer">
				<img src={sketches[6].image} alt={sketches[6].title}
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-4 md:p-5">
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/40 mb-1">{sketches[6].category}</p>
					<p class="text-sm md:text-lg font-['Playfair_Display',serif]">{sketches[6].title}</p>
				</div>
			</div>

			<!-- Card 8: Temple Ruins — wide bottom -->
			<div class="bento-card group col-span-1 md:col-span-2 row-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-white/5 cursor-pointer">
				<img src={sketches[7].image} alt={sketches[7].title}
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-4 md:p-6">
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/40 mb-1">{sketches[7].category}</p>
					<p class="text-base md:text-xl font-['Playfair_Display',serif]">{sketches[7].title}</p>
				</div>
			</div>

			<!-- IG card -->
			<div class="bento-card col-span-1 relative overflow-hidden rounded-xl md:rounded-2xl bg-white/[0.03] border border-white/5 flex flex-col justify-center items-center p-4 md:p-6 text-center">
				<svg class="w-6 h-6 md:w-8 md:h-8 text-white/20 mb-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
				<a href="https://www.instagram.com/sketching_.wid_.heart" target="_blank" rel="noopener"
					class="text-[9px] md:text-[10px] uppercase tracking-[0.2em] text-white/30 hover:text-white/60 transition-colors">
					@sketching_.wid_.heart
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.bento-card {
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease;
	}
	.bento-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.5);
	}
</style>
