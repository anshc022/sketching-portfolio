---
const sketches = [
	{ id: 1, title: 'Portrait Study', category: 'Portrait', image: '/artworks/sketch_01.png' },
	{ id: 2, title: 'Mountain Serenity', category: 'Landscape', image: '/artworks/sketch_02.png' },
	{ id: 3, title: 'Lotus Bloom', category: 'Detail', image: '/artworks/sketch_03.png' },
	{ id: 4, title: 'Wisdom Lines', category: 'Portrait', image: '/artworks/sketch_04.png' },
	{ id: 5, title: 'Vintage Journey', category: 'Object', image: '/artworks/sketch_05.png' },
	{ id: 6, title: 'Wild Gaze', category: 'Detail', image: '/artworks/sketch_06.png' },
	{ id: 7, title: 'Grace in Motion', category: 'Portrait', image: '/artworks/sketch_07.png' },
	{ id: 8, title: 'Temple Ruins', category: 'Landscape', image: '/artworks/sketch_08.png' },
];
---

<!-- Marquee -->
<div class="py-8 md:py-10 overflow-hidden border-y border-[#1a1a1a]/[0.08] dark:border-white/[0.06] bg-gradient-to-r from-amber-500/[0.02] via-transparent to-amber-500/[0.02] dark:from-amber-400/[0.01] dark:via-transparent dark:to-amber-400/[0.01]">
	<div class="animate-marquee whitespace-nowrap flex">
		{[...Array(3)].map(() => (
			<span class="inline-flex items-center">
				{sketches.map((s, i) => (
					<>
						<span class="text-2xl md:text-4xl font-['Playfair_Display',serif] text-[#1a1a1a]/[0.12] dark:text-white/[0.08] mx-6 md:mx-10 hover:text-amber-500/30 dark:hover:text-amber-400/20 transition-colors duration-500 cursor-default">{s.title}</span>
						<span class="w-2 h-2 rounded-full bg-amber-500/[0.15] dark:bg-amber-400/[0.1]"></span>
					</>
				))}
			</span>
		))}
	</div>
</div>

<section id="gallery" class="relative py-20 md:py-32 px-4 md:px-8 lg:px-12">
	<div class="max-w-[1400px] mx-auto">
		<div class="mb-12 md:mb-20 reveal">
			<div class="flex items-end justify-between">
				<div>
					<p class="text-[11px] uppercase tracking-[0.5em] text-amber-600/50 dark:text-amber-400/40 mb-4">Selected Works</p>
					<h2 class="text-4xl md:text-7xl font-bold">Gallery</h2>
				</div>
				<p class="hidden md:block text-[11px] uppercase tracking-[0.3em] text-[#1a1a1a]/20 dark:text-white/20 pb-2">
					{sketches.length} pieces — 2023-present
				</p>
			</div>
			<div class="h-[1px] bg-[#1a1a1a]/5 dark:bg-white/5 mt-8 line-draw"></div>
		</div>

		<div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3 lg:gap-4 auto-rows-[130px] sm:auto-rows-[160px] md:auto-rows-[190px] lg:auto-rows-[220px]">
			
			<!-- Card 1: hero -->
			<div class="bento-card group row-span-2 col-span-2 md:row-span-3 relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/5 dark:bg-white/5 cursor-pointer reveal"
				data-lightbox={sketches[0].image} data-title={sketches[0].title} data-category={sketches[0].category}>
				<img src={sketches[0].image} alt={sketches[0].title}
					class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105 group-hover:brightness-110" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/5 to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-4 md:p-6 lg:p-8">
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/40 mb-1 md:mb-2">{sketches[0].category}</p>
					<p class="text-lg md:text-2xl lg:text-3xl font-['Playfair_Display',serif] text-white">{sketches[0].title}</p>
				</div>
				<div class="absolute top-3 right-3 md:top-5 md:right-5 w-8 h-8 md:w-10 md:h-10 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 scale-75 group-hover:scale-100">
					<svg class="w-3 h-3 md:w-4 md:h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
				</div>
				<div class="absolute top-3 left-3 md:top-5 md:left-5"><span class="text-[10px] font-['Space_Mono',monospace] text-white/20">01</span></div>
			</div>

			<!-- Card 2 -->
			<div class="bento-card group col-span-1 md:col-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/5 dark:bg-white/5 cursor-pointer reveal reveal-delay-1"
				data-lightbox={sketches[1].image} data-title={sketches[1].title} data-category={sketches[1].category}>
				<img src={sketches[1].image} alt={sketches[1].title} class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-3 md:p-5">
					<p class="text-[9px] uppercase tracking-[0.3em] text-white/40 mb-0.5">{sketches[1].category}</p>
					<p class="text-sm md:text-lg font-['Playfair_Display',serif] text-white">{sketches[1].title}</p>
				</div>
				<div class="absolute top-2 left-2 md:top-4 md:left-4"><span class="text-[10px] font-['Space_Mono',monospace] text-white/20">02</span></div>
			</div>

			<!-- Card 3 -->
			<div class="bento-card group relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/5 dark:bg-white/5 cursor-pointer reveal reveal-delay-2"
				data-lightbox={sketches[2].image} data-title={sketches[2].title} data-category={sketches[2].category}>
				<img src={sketches[2].image} alt={sketches[2].title} class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-3 md:p-4">
					<p class="text-xs md:text-sm font-['Playfair_Display',serif] text-white">{sketches[2].title}</p>
				</div>
				<div class="absolute top-2 left-2 md:top-3 md:left-3"><span class="text-[9px] font-['Space_Mono',monospace] text-white/15">03</span></div>
			</div>

			<!-- Stats card -->
			<div class="bento-card col-span-1 relative overflow-hidden rounded-xl md:rounded-2xl bg-gradient-to-br from-amber-500/[0.08] to-amber-500/[0.02] dark:from-amber-400/[0.06] dark:to-amber-400/[0.02] border border-amber-500/[0.1] dark:border-amber-400/[0.08] flex flex-col justify-between p-4 md:p-6 reveal reveal-delay-2">
				<div>
					<div class="w-8 h-8 md:w-10 md:h-10 rounded-full border border-amber-500/20 dark:border-amber-400/20 flex items-center justify-center mb-4 md:mb-6">
						<svg class="w-3.5 h-3.5 md:w-4 md:h-4 text-amber-500/50 dark:text-amber-400/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
					</div>
					<p class="text-3xl md:text-5xl font-['Playfair_Display',serif] font-bold leading-none text-amber-600/80 dark:text-amber-400/80">50+</p>
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-amber-600/30 dark:text-amber-400/30 mt-1">Artworks</p>
				</div>
				<div class="flex gap-1 mt-4">
					{[...Array(5)].map((_, i) => (
						<div class="h-[2px] flex-1 rounded-full" style={`background: rgba(251,191,36,${0.08 + i * 0.06})`}></div>
					))}
				</div>
			</div>

			<!-- Card 4: tall -->
			<div class="bento-card group row-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/5 dark:bg-white/5 cursor-pointer reveal reveal-delay-1"
				data-lightbox={sketches[3].image} data-title={sketches[3].title} data-category={sketches[3].category}>
				<img src={sketches[3].image} alt={sketches[3].title} class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-3 md:p-5">
					<p class="text-[9px] uppercase tracking-[0.3em] text-white/40 mb-0.5">{sketches[3].category}</p>
					<p class="text-sm md:text-lg font-['Playfair_Display',serif] text-white">{sketches[3].title}</p>
				</div>
				<div class="absolute top-2 left-2 md:top-4 md:left-4"><span class="text-[10px] font-['Space_Mono',monospace] text-white/20">04</span></div>
			</div>

			<!-- Card 5: wide -->
			<div class="bento-card group col-span-1 md:col-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/5 dark:bg-white/5 cursor-pointer reveal reveal-delay-2"
				data-lightbox={sketches[4].image} data-title={sketches[4].title} data-category={sketches[4].category}>
				<img src={sketches[4].image} alt={sketches[4].title} class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-3 md:p-5">
					<p class="text-[9px] uppercase tracking-[0.3em] text-white/40 mb-0.5">{sketches[4].category}</p>
					<p class="text-sm md:text-lg font-['Playfair_Display',serif] text-white">{sketches[4].title}</p>
				</div>
				<div class="absolute top-2 left-2 md:top-4 md:left-4"><span class="text-[10px] font-['Space_Mono',monospace] text-white/20">05</span></div>
			</div>

			<!-- Card 6 -->
			<div class="bento-card group relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/5 dark:bg-white/5 cursor-pointer reveal reveal-delay-3"
				data-lightbox={sketches[5].image} data-title={sketches[5].title} data-category={sketches[5].category}>
				<img src={sketches[5].image} alt={sketches[5].title} class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-3 md:p-4">
					<p class="text-xs md:text-sm font-['Playfair_Display',serif] text-white">{sketches[5].title}</p>
				</div>
				<div class="absolute top-2 left-2 md:top-3 md:left-3"><span class="text-[9px] font-['Space_Mono',monospace] text-white/15">06</span></div>
			</div>

			<!-- IG card -->
			<div class="bento-card col-span-1 relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/[0.02] dark:bg-white/[0.02] border border-[#1a1a1a]/[0.06] dark:border-white/[0.06] flex flex-col justify-center items-center p-4 md:p-6 text-center reveal reveal-delay-3">
				<div class="w-12 h-12 md:w-14 md:h-14 rounded-full border border-[#1a1a1a]/10 dark:border-white/10 flex items-center justify-center mb-3 group cursor-pointer hover:border-amber-500/30 dark:hover:border-amber-400/20 transition-colors">
					<svg class="w-5 h-5 md:w-6 md:h-6 text-[#1a1a1a]/20 dark:text-white/20 group-hover:text-amber-500/50 dark:group-hover:text-amber-400/40 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
				</div>
				<a href="https://www.instagram.com/sketching_.wid_.heart" target="_blank" rel="noopener"
					class="text-[9px] md:text-[10px] uppercase tracking-[0.2em] text-[#1a1a1a]/25 dark:text-white/25 hover:text-amber-500/60 dark:hover:text-amber-400/50 transition-colors">
					Follow
				</a>
			</div>

			<!-- Card 7: tall -->
			<div class="bento-card group row-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/5 dark:bg-white/5 cursor-pointer reveal reveal-delay-2"
				data-lightbox={sketches[6].image} data-title={sketches[6].title} data-category={sketches[6].category}>
				<img src={sketches[6].image} alt={sketches[6].title} class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-3 md:p-5">
					<p class="text-[9px] uppercase tracking-[0.3em] text-white/40 mb-0.5">{sketches[6].category}</p>
					<p class="text-sm md:text-lg font-['Playfair_Display',serif] text-white">{sketches[6].title}</p>
				</div>
				<div class="absolute top-2 left-2 md:top-4 md:left-4"><span class="text-[10px] font-['Space_Mono',monospace] text-white/20">07</span></div>
			</div>

			<!-- Card 8: wide -->
			<div class="bento-card group col-span-1 md:col-span-2 row-span-2 relative overflow-hidden rounded-xl md:rounded-2xl bg-[#1a1a1a]/5 dark:bg-white/5 cursor-pointer reveal reveal-delay-3"
				data-lightbox={sketches[7].image} data-title={sketches[7].title} data-category={sketches[7].category}>
				<img src={sketches[7].image} alt={sketches[7].title} class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-4 md:p-6">
					<p class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/40 mb-1">{sketches[7].category}</p>
					<p class="text-base md:text-2xl font-['Playfair_Display',serif] text-white">{sketches[7].title}</p>
				</div>
				<div class="absolute top-2 left-2 md:top-5 md:left-5"><span class="text-[10px] font-['Space_Mono',monospace] text-white/20">08</span></div>
			</div>

			<!-- CTA card -->
			<div class="bento-card col-span-1 relative overflow-hidden rounded-xl md:rounded-2xl border border-amber-500/[0.12] dark:border-amber-400/[0.1] flex flex-col justify-center items-center p-4 md:p-6 text-center cursor-pointer reveal reveal-delay-4"
				style="background: linear-gradient(135deg, rgba(251,191,36,0.06) 0%, rgba(251,191,36,0.02) 100%);">
				<p class="text-xs md:text-sm font-['Playfair_Display',serif] italic text-[#1a1a1a]/30 dark:text-white/30 mb-3">Want a custom piece?</p>
				<a href="#commission" class="magnetic-btn px-5 py-2.5 rounded-full border border-amber-500/20 dark:border-amber-400/20 text-[10px] uppercase tracking-[0.2em] text-amber-600/60 dark:text-amber-400/60 hover:text-amber-600 dark:hover:text-amber-400 hover:border-amber-500/40 dark:hover:border-amber-400/40 transition-all">
					Commission
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.bento-card { transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease; }
	.bento-card:hover { transform: translateY(-3px); box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); }
	:global(.dark) .bento-card:hover { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6); }
</style>
