---
---

<!-- Testimonials / Kind Words section -->
<section class="relative py-20 md:py-32 overflow-hidden">
	<div class="max-w-[1400px] mx-auto px-4 md:px-8 lg:px-12">
		<div class="reveal mb-16 md:mb-20">
			<p class="text-[11px] uppercase tracking-[0.5em] text-amber-600/50 dark:text-amber-400/40 mb-4">Testimonials</p>
			<h2 class="text-4xl md:text-7xl font-bold">Kind Words</h2>
			<div class="h-[1px] bg-[#1a1a1a]/5 dark:bg-white/5 mt-8 line-draw"></div>
		</div>

		<div class="grid md:grid-cols-3 gap-4 md:gap-6">
			{[
				{
					quote: "Varsha captured my grandmother's essence perfectly. Every wrinkle, every smile line — it's like she's still here with us.",
					name: "Priya S.",
					type: "Portrait Commission",
					stars: 5
				},
				{
					quote: "I've never seen someone bring so much emotion out of graphite. The shading and detail in my pet portrait blew me away.",
					name: "Rahul M.",
					type: "Pet Portrait",
					stars: 5
				},
				{
					quote: "From the first sketch update to the final piece — the whole process felt personal and thoughtful. Truly gifted artist.",
					name: "Ananya K.",
					type: "Custom Artwork",
					stars: 5
				}
			].map((t, i) => (
				<div class={`reveal reveal-delay-${i + 1} group bg-[#1a1a1a]/[0.02] dark:bg-white/[0.02] border border-[#1a1a1a]/[0.06] dark:border-white/[0.06] rounded-xl md:rounded-2xl p-6 md:p-8 hover:border-amber-500/15 dark:hover:border-amber-400/10 transition-all duration-500`}>
					<div class="flex gap-1 mb-5">
						{[...Array(t.stars)].map(() => (
							<svg class="w-3.5 h-3.5 text-amber-500/50 dark:text-amber-400/40" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
						))}
					</div>
					<p class="text-sm md:text-[15px] leading-[1.8] text-[#1a1a1a]/40 dark:text-white/35 italic font-['Playfair_Display',serif] mb-6">"{t.quote}"</p>
					<div class="flex items-center gap-3">
						<div class="w-8 h-8 rounded-full bg-gradient-to-br from-amber-500/20 to-amber-500/5 dark:from-amber-400/15 dark:to-amber-400/5 flex items-center justify-center">
							<span class="text-[10px] font-medium text-amber-600/60 dark:text-amber-400/50">{t.name.charAt(0)}</span>
						</div>
						<div>
							<p class="text-xs font-medium text-[#1a1a1a]/50 dark:text-white/50">{t.name}</p>
							<p class="text-[10px] text-[#1a1a1a]/20 dark:text-white/20">{t.type}</p>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
