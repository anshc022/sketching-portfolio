---
const crafts = [
	{ image: '/artworks/craft_graphite.png', name: 'Graphite Pencils', desc: 'HB to 8B range for subtle to deep tones. The foundation of every sketch — from whisper-light guidelines to rich, velvety darks.', detail: 'Primary medium', num: '01' },
	{ image: '/artworks/craft_charcoal.png', name: 'Charcoal', desc: 'Rich blacks and dramatic contrast. When a piece needs raw energy and bold expression, charcoal brings the drama.', detail: 'Expressive work', num: '02' },
	{ image: '/artworks/craft_blending.png', name: 'Blending Stumps', desc: 'Smooth gradients and skin textures. The secret weapon for photorealistic transitions and lifelike softness.', detail: 'Detail finishing', num: '03' },
	{ image: '/artworks/craft_paper.png', name: 'Mixed Paper', desc: 'Cold-pressed, smooth bristol, toned — each surface tells the story differently. The paper is as important as the pencil.', detail: 'Surface variety', num: '04' },
];
---

<section class="relative py-16 md:py-24" id="craft-section">
	<div class="max-w-[1400px] mx-auto px-4 md:px-8 lg:px-12">
		<div class="reveal mb-10 md:mb-14">
			<p class="text-[11px] uppercase tracking-[0.5em] text-amber-600/50 dark:text-amber-400/40 mb-4">Tools & Mediums</p>
			<h2 class="text-3xl md:text-5xl font-bold">The Craft</h2>
			<div class="h-[1px] bg-[#1a1a1a]/5 dark:bg-white/5 mt-6 line-draw"></div>
		</div>
	</div>

	<!-- Stacked cards container — works on both mobile and desktop -->
	<div class="craft-stack-container relative">
		{crafts.map((m, i) => (
			<div class="craft-sticky-card px-4 md:px-8 lg:px-12 py-2 md:py-4"
				style={`position: sticky; top: ${60 + i * 20}px; z-index: ${10 + i};`}>
				<div class="max-w-[1400px] mx-auto bg-[#f0efe9] dark:bg-[#141414] border border-[#1a1a1a]/[0.08] dark:border-white/[0.06] rounded-2xl md:rounded-3xl overflow-hidden craft-card-shadow">
					
					<!-- Mobile: vertical card | Desktop: horizontal split -->
					<div class="flex flex-col md:grid md:grid-cols-2 md:gap-0">
						<!-- Image -->
						<div class="h-48 sm:h-56 md:h-[400px] lg:h-[450px] overflow-hidden relative">
							<img src={m.image} alt={m.name} class="w-full h-full object-cover" loading="lazy" />
							<div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-[#f0efe9]/40 dark:from-[#141414]/40 md:from-transparent md:to-[#f0efe9]/20 md:dark:to-[#141414]/30 to-transparent"></div>
							<!-- Number badge -->
							<div class="absolute top-3 left-3 md:top-6 md:left-6">
								<span class="text-[10px] md:text-[11px] font-['Space_Mono',monospace] text-white/50 bg-black/25 backdrop-blur-md px-2.5 py-1 md:px-3 md:py-1.5 rounded-full">{m.num}</span>
							</div>
						</div>

						<!-- Content -->
						<div class="flex flex-col justify-center p-5 sm:p-6 md:p-10 lg:p-14">
							<span class="text-[9px] uppercase tracking-[0.3em] text-amber-600/40 dark:text-amber-400/30 mb-2 md:mb-4">{m.detail}</span>
							<h3 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-['Playfair_Display',serif] font-bold mb-3 md:mb-5">{m.name}</h3>
							<p class="text-xs sm:text-sm md:text-[15px] leading-[1.7] md:leading-[1.8] text-[#1a1a1a]/40 dark:text-white/35 mb-4 md:mb-8">{m.desc}</p>
							<div class="flex items-center gap-3">
								<div class="h-[1px] flex-1 bg-gradient-to-r from-amber-500/20 dark:from-amber-400/15 to-transparent"></div>
								<span class="text-[10px] font-['Space_Mono',monospace] text-[#1a1a1a]/15 dark:text-white/15">{m.num} / 04</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		))}

		<!-- Spacer so the last card has room to fully scroll into view -->
		<div class="h-[30vh] md:h-[35vh]"></div>
	</div>
</section>

<style>
	.craft-card-shadow {
		box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08), 0 4px 12px -4px rgba(0, 0, 0, 0.04);
	}
	:global(.dark) .craft-card-shadow {
		box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.4), 0 4px 12px -4px rgba(0, 0, 0, 0.2);
	}
</style>
