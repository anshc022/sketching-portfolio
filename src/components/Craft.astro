---
const crafts = [
	{ image: '/artworks/craft_graphite.png', name: 'Graphite Pencils', desc: 'HB to 8B range for subtle to deep tones. The foundation of every sketch — from whisper-light guidelines to rich, velvety darks.', detail: 'Primary medium', num: '01' },
	{ image: '/artworks/craft_charcoal.png', name: 'Charcoal', desc: 'Rich blacks and dramatic contrast. When a piece needs raw energy and bold expression, charcoal brings the drama.', detail: 'Expressive work', num: '02' },
	{ image: '/artworks/craft_blending.png', name: 'Blending Stumps', desc: 'Smooth gradients and skin textures. The secret weapon for photorealistic transitions and lifelike softness.', detail: 'Detail finishing', num: '03' },
	{ image: '/artworks/craft_paper.png', name: 'Mixed Paper', desc: 'Cold-pressed, smooth bristol, toned — each surface tells the story differently. The paper is as important as the pencil.', detail: 'Surface variety', num: '04' },
];
---

<section class="relative py-16 md:py-24" id="craft-section">
	<div class="max-w-[1400px] mx-auto px-4 md:px-8 lg:px-12">
		<div class="reveal mb-10 md:mb-14">
			<p class="text-[11px] uppercase tracking-[0.5em] text-amber-600/50 dark:text-amber-400/40 mb-4">Tools & Mediums</p>
			<h2 class="text-3xl md:text-5xl font-bold">The Craft</h2>
			<div class="h-[1px] bg-[#1a1a1a]/5 dark:bg-white/5 mt-6 line-draw"></div>
		</div>
	</div>

	<!-- Stacked cards container -->
	<div class="craft-stack-container relative">
		{crafts.map((m, i) => (
			<div class="craft-sticky-card sticky px-4 md:px-8 lg:px-12"
				style={`top: ${80 + i * 30}px; z-index: ${10 + i};`}>
				<div class={`max-w-[1400px] mx-auto bg-[#f0efe9] dark:bg-[#141414] border border-[#1a1a1a]/[0.08] dark:border-white/[0.06] rounded-2xl md:rounded-3xl overflow-hidden shadow-xl shadow-black/5 dark:shadow-black/30 transition-all duration-500`}>
					<div class="grid md:grid-cols-2 gap-0">
						<!-- Image -->
						<div class="aspect-[4/3] md:aspect-auto md:h-[400px] lg:h-[450px] overflow-hidden relative">
							<img src={m.image} alt={m.name} class="w-full h-full object-cover" loading="lazy" />
							<div class="absolute inset-0 bg-gradient-to-r from-transparent to-[#f0efe9]/20 dark:to-[#141414]/30 hidden md:block"></div>
							<!-- Number overlay -->
							<div class="absolute top-4 left-4 md:top-6 md:left-6">
								<span class="text-[11px] font-['Space_Mono',monospace] text-white/40 bg-black/20 backdrop-blur-md px-3 py-1.5 rounded-full">{m.num}</span>
							</div>
						</div>

						<!-- Content -->
						<div class="flex flex-col justify-center p-6 md:p-10 lg:p-14">
							<span class="text-[9px] uppercase tracking-[0.3em] text-amber-600/40 dark:text-amber-400/30 mb-3 md:mb-4">{m.detail}</span>
							<h3 class="text-2xl md:text-3xl lg:text-4xl font-['Playfair_Display',serif] font-bold mb-4 md:mb-5">{m.name}</h3>
							<p class="text-sm md:text-[15px] leading-[1.8] text-[#1a1a1a]/40 dark:text-white/35 mb-6 md:mb-8">{m.desc}</p>
							<div class="flex items-center gap-3">
								<div class="h-[1px] flex-1 bg-gradient-to-r from-amber-500/20 dark:from-amber-400/15 to-transparent"></div>
								<span class="text-[10px] font-['Space_Mono',monospace] text-[#1a1a1a]/15 dark:text-white/15">{m.num} / 04</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		))}

		<!-- Spacer so the last card has room to scroll into place -->
		<div class="h-[20vh] md:h-[30vh]"></div>
	</div>
</section>

<style>
	.craft-stack-container {
		/* Each card is ~500px tall on desktop; we need enough scroll height */
	}
	.craft-sticky-card {
		padding-top: 1rem;
		padding-bottom: 1rem;
	}

	/* On mobile, disable sticky stacking — just show normally */
	@media (max-width: 767px) {
		.craft-sticky-card {
			position: relative !important;
			top: 0 !important;
			padding-top: 0.5rem;
			padding-bottom: 0.5rem;
		}
		.craft-stack-container > div:last-child {
			height: 0 !important;
		}
	}
</style>
