---
---

<!-- Medium showcase strip -->
<section class="py-16 md:py-24 overflow-hidden">
	<div class="max-w-[1400px] mx-auto px-4 md:px-8 lg:px-12">
		<div class="reveal mb-10 md:mb-14">
			<p class="text-[11px] uppercase tracking-[0.5em] text-amber-600/50 dark:text-amber-400/40 mb-4">Tools & Mediums</p>
			<h2 class="text-3xl md:text-5xl font-bold">The Craft</h2>
			<div class="h-[1px] bg-[#1a1a1a]/5 dark:bg-white/5 mt-6 line-draw"></div>
		</div>

		<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
			{[
				{ icon: '✏️', name: 'Graphite Pencils', desc: 'HB to 8B range for subtle to deep tones', detail: 'Primary medium' },
				{ icon: '🖤', name: 'Charcoal', desc: 'Rich blacks and dramatic contrast', detail: 'Expressive work' },
				{ icon: '📐', name: 'Blending Stumps', desc: 'Smooth gradients and skin textures', detail: 'Detail finishing' },
				{ icon: '📄', name: 'Mixed Paper', desc: 'Cold-pressed, smooth bristol, toned', detail: 'Surface variety' },
			].map((m, i) => (
				<div class={`reveal reveal-delay-${i + 1} group bg-[#1a1a1a]/[0.02] dark:bg-white/[0.02] border border-[#1a1a1a]/[0.06] dark:border-white/[0.06] rounded-xl md:rounded-2xl p-5 md:p-7 hover:border-amber-500/15 dark:hover:border-amber-400/10 transition-all duration-500 cursor-default`}>
					<div class="text-2xl md:text-3xl mb-4 md:mb-5 group-hover:scale-110 transition-transform duration-300">{m.icon}</div>
					<p class="text-sm md:text-base font-['Playfair_Display',serif] mb-1.5">{m.name}</p>
					<p class="text-[11px] md:text-xs text-[#1a1a1a]/30 dark:text-white/25 leading-relaxed mb-3">{m.desc}</p>
					<span class="text-[9px] uppercase tracking-[0.2em] text-amber-600/30 dark:text-amber-400/20">{m.detail}</span>
				</div>
			))}
		</div>
	</div>
</section>
