---
---

<!-- Parallax About Section -->
<section id="about" class="relative py-32 overflow-hidden">
	<div class="absolute inset-0 opacity-[0.02]"
		style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;">
	</div>

	<div class="max-w-7xl mx-auto px-8">
		<div class="grid md:grid-cols-2 gap-16 lg:gap-24 items-center">
			<div class="relative">
				<div class="aspect-[3/4] rounded-2xl overflow-hidden bg-gradient-to-br from-white/[0.08] to-white/[0.02] border border-white/5">
					<div class="absolute inset-0 flex items-center justify-center">
						<span class="text-white/10 text-xs uppercase tracking-widest">Artist Photo</span>
					</div>
				</div>
				<!-- Floating accent -->
				<div class="absolute -bottom-6 -right-6 w-32 h-32 rounded-full border border-white/5 flex items-center justify-center">
					<div class="text-center">
						<span class="block text-2xl font-['Playfair_Display'] font-bold">3+</span>
						<span class="text-[9px] uppercase tracking-widest text-white/40">Years</span>
					</div>
				</div>
			</div>

			<div>
				<p class="text-[11px] uppercase tracking-[0.5em] text-white/30 mb-6">The Artist</p>
				<h2 class="text-5xl md:text-6xl font-bold mb-8">Varsha</h2>

				<div class="space-y-5 text-white/40 text-[15px] leading-relaxed">
					<p>
						Every sketch begins with a feeling. Working primarily in graphite and charcoal,
						I'm drawn to the way simple pencil strokes can capture emotion, light, and the
						quiet beauty in everyday moments.
					</p>
					<p>
						My journey started with a love for observation — noticing the way shadows fall
						across a face, how textures shift in natural light. Each piece is a conversation
						between the paper and me.
					</p>
				</div>

				<!-- Stats -->
				<div class="grid grid-cols-3 gap-8 mt-12 pt-8 border-t border-white/5">
					{[
						{ num: '50+', label: 'Artworks' },
						{ num: '20+', label: 'Commissions' },
						{ num: '100+', label: 'Followers' },
					].map(stat => (
						<div>
							<span class="block text-3xl font-['Playfair_Display'] font-bold">{stat.num}</span>
							<span class="text-[10px] uppercase tracking-widest text-white/30 mt-1">{stat.label}</span>
						</div>
					))}
				</div>

				<div class="flex gap-4 mt-12">
					<a href="https://www.instagram.com/sketching_.wid_.heart" target="_blank" rel="noopener"
						class="px-8 py-4 bg-white text-[#0a0a0a] text-[11px] uppercase tracking-[0.2em] font-medium hover:bg-white/90 transition-colors rounded-full">
						Follow on Instagram
					</a>
					<a href="https://www.instagram.com/varsha.r_.o" target="_blank" rel="noopener"
						class="px-8 py-4 border border-white/10 text-[11px] uppercase tracking-[0.2em] text-white/60 hover:text-white hover:border-white/30 transition-all rounded-full">
						Personal
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
