---
---

<section class="relative py-20 md:py-28">
	<div class="max-w-[800px] mx-auto px-4 md:px-8">
		<div class="text-center reveal mb-14 md:mb-20">
			<p class="text-[11px] uppercase tracking-[0.5em] text-amber-600/50 dark:text-amber-400/40 mb-4">Common Questions</p>
			<h2 class="text-4xl md:text-6xl font-bold">FAQ</h2>
		</div>

		<div class="space-y-3 md:space-y-4">
			{[
				{ q: 'How long does a commission take?', a: 'Typically 1-3 weeks depending on size and complexity. A5 portraits can be done in a week, while detailed A3 pieces may take 2-3 weeks. Rush orders are available for an additional fee.' },
				{ q: 'What reference photos work best?', a: 'Clear, well-lit photos with good resolution work best. Natural lighting is ideal. I can work with multiple reference photos to composite the perfect piece.' },
				{ q: 'Do you ship internationally?', a: 'Yes! All originals are carefully packaged with acid-free materials and shipped with tracking. Domestic shipping is free, international rates vary by location.' },
				{ q: 'Can I get a digital copy too?', a: 'Absolutely. Every commission includes a high-resolution digital scan of the finished artwork, perfect for printing or sharing online.' },
				{ q: 'What if I want changes?', a: 'I share progress photos at every stage. Minor revisions are included. Major changes after the final stage may incur additional costs, discussed upfront.' },
			].map((faq, i) => (
				<div class={`reveal reveal-delay-${Math.min(i + 1, 4)} faq-item border border-[#1a1a1a]/[0.06] dark:border-white/[0.06] rounded-xl md:rounded-2xl overflow-hidden transition-all duration-300 hover:border-amber-500/15 dark:hover:border-amber-400/10`}>
					<button class="faq-toggle w-full flex items-center justify-between p-5 md:p-6 text-left cursor-pointer" aria-expanded="false">
						<span class="text-sm md:text-[15px] font-medium text-[#1a1a1a]/60 dark:text-white/60 pr-4">{faq.q}</span>
						<div class="flex-shrink-0 w-7 h-7 md:w-8 md:h-8 rounded-full border border-[#1a1a1a]/10 dark:border-white/10 flex items-center justify-center transition-all duration-300">
							<svg class="faq-icon w-3 h-3 md:w-3.5 md:h-3.5 text-[#1a1a1a]/25 dark:text-white/25 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"/></svg>
						</div>
					</button>
					<div class="faq-answer overflow-hidden transition-all duration-500" style="max-height: 0;">
						<div class="px-5 md:px-6 pb-5 md:pb-6">
							<p class="text-xs md:text-sm leading-[1.8] text-[#1a1a1a]/30 dark:text-white/25">{faq.a}</p>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	document.querySelectorAll('.faq-toggle').forEach(btn => {
		btn.addEventListener('click', () => {
			const item = btn.closest('.faq-item');
			const answer = item?.querySelector('.faq-answer') as HTMLElement;
			const icon = item?.querySelector('.faq-icon');
			const isOpen = btn.getAttribute('aria-expanded') === 'true';

			// Close all others
			document.querySelectorAll('.faq-item').forEach(other => {
				if (other !== item) {
					const otherAnswer = other.querySelector('.faq-answer') as HTMLElement;
					const otherIcon = other.querySelector('.faq-icon');
					const otherBtn = other.querySelector('.faq-toggle');
					if (otherAnswer) otherAnswer.style.maxHeight = '0';
					otherIcon?.classList.remove('rotate-45');
					otherBtn?.setAttribute('aria-expanded', 'false');
				}
			});

			if (isOpen) {
				if (answer) answer.style.maxHeight = '0';
				icon?.classList.remove('rotate-45');
				btn.setAttribute('aria-expanded', 'false');
			} else {
				if (answer) answer.style.maxHeight = answer.scrollHeight + 'px';
				icon?.classList.add('rotate-45');
				btn.setAttribute('aria-expanded', 'true');
			}
		});
	});
</script>
