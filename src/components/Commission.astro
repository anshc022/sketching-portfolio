---
---

<section id="commission" class="relative py-32">
	<div class="max-w-5xl mx-auto px-8">
		<div class="text-center mb-16">
			<p class="text-[11px] uppercase tracking-[0.5em] text-white/30 mb-4">Work with Me</p>
			<h2 class="text-5xl md:text-6xl font-bold mb-6">Commission</h2>
			<p class="text-white/30 text-sm max-w-lg mx-auto">
				Want a custom portrait, pet sketch, or illustration? Fill out the form and I'll
				get back to you within 48 hours.
			</p>
		</div>

		<div class="grid md:grid-cols-5 gap-12">
			<div class="md:col-span-3">
				<form class="space-y-6" id="commission-form">
					<div class="grid grid-cols-2 gap-4">
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-white/30 mb-3">Name</label>
							<input type="text" name="name" required
								class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30 transition-colors" 
								placeholder="Your name" />
						</div>
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-white/30 mb-3">Email</label>
							<input type="email" name="email" required
								class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30 transition-colors"
								placeholder="you@email.com" />
						</div>
					</div>

					<div class="grid grid-cols-2 gap-4">
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-white/30 mb-3">Size</label>
							<select name="size"
								class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-sm text-white/60 focus:outline-none focus:border-white/30 transition-colors">
								<option value="a5">A5 — Small</option>
								<option value="a4" selected>A4 — Standard</option>
								<option value="a3">A3 — Large</option>
								<option value="custom">Custom</option>
							</select>
						</div>
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-white/30 mb-3">Medium</label>
							<select name="medium"
								class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-sm text-white/60 focus:outline-none focus:border-white/30 transition-colors">
								<option value="graphite" selected>Graphite Pencil</option>
								<option value="charcoal">Charcoal</option>
								<option value="mixed">Mixed Media</option>
							</select>
						</div>
					</div>

					<div>
						<label class="block text-[10px] uppercase tracking-widest text-white/30 mb-3">Reference Photo</label>
						<label for="file-upload" class="block border-2 border-dashed border-white/10 rounded-lg p-8 text-center cursor-pointer hover:border-white/20 transition-colors">
							<input type="file" id="file-upload" name="reference" accept="image/*" class="hidden" />
							<svg class="w-8 h-8 mx-auto mb-3 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
							<p class="text-white/20 text-xs">Click to upload reference</p>
							<p class="text-white/10 text-[10px] mt-1">JPG, PNG up to 10MB</p>
						</label>
					</div>

					<div>
						<label class="block text-[10px] uppercase tracking-widest text-white/30 mb-3">Details</label>
						<textarea name="details" rows="4"
							class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30 transition-colors resize-none"
							placeholder="Tell me about your vision..."></textarea>
					</div>

					<button type="submit"
						class="w-full bg-white text-[#0a0a0a] rounded-full py-4 text-[11px] uppercase tracking-[0.2em] font-medium hover:bg-white/90 transition-colors">
						Submit Request
					</button>
				</form>
			</div>

			<div class="md:col-span-2">
				<div class="sticky top-32 space-y-10">
					<div class="bg-white/[0.03] border border-white/5 rounded-2xl p-8">
						<h3 class="font-['Playfair_Display'] text-xl mb-6">How it works</h3>
						<div class="space-y-5">
							{[
								{ step: '01', text: 'Submit your request with a reference photo' },
								{ step: '02', text: 'Receive a quote within 48 hours' },
								{ step: '03', text: 'Progress updates with WIP photos' },
								{ step: '04', text: 'Final delivery — digital + physical' },
							].map(item => (
								<div class="flex gap-4 items-start">
									<span class="text-white/10 font-['Playfair_Display'] text-lg font-bold">{item.step}</span>
									<p class="text-white/40 text-sm">{item.text}</p>
								</div>
							))}
						</div>
					</div>

					<div class="bg-white/[0.03] border border-white/5 rounded-2xl p-8">
						<h3 class="font-['Playfair_Display'] text-xl mb-4">Timeline</h3>
						<p class="text-white/40 text-sm leading-relaxed">
							Most commissions take 1-3 weeks depending on size and complexity.
							Rush orders available upon request.
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
