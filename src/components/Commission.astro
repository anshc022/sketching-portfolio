---
---

<!-- Second marquee before commission -->
<div class="py-6 md:py-8 overflow-hidden border-y border-white/5">
	<div class="animate-marquee whitespace-nowrap flex" style="animation-direction: reverse; animation-duration: 25s;">
		{[...Array(4)].map(() => (
			<span class="inline-flex items-center">
				<span class="text-lg md:text-2xl font-['Playfair_Display',serif] italic text-white/[0.05] mx-8 md:mx-12">Commission</span>
				<span class="w-1 h-1 rounded-full bg-white/[0.05]"></span>
				<span class="text-lg md:text-2xl font-['Playfair_Display',serif] italic text-white/[0.05] mx-8 md:mx-12">Custom Artwork</span>
				<span class="w-1 h-1 rounded-full bg-white/[0.05]"></span>
				<span class="text-lg md:text-2xl font-['Playfair_Display',serif] italic text-white/[0.05] mx-8 md:mx-12">Portraits</span>
				<span class="w-1 h-1 rounded-full bg-white/[0.05]"></span>
				<span class="text-lg md:text-2xl font-['Playfair_Display',serif] italic text-white/[0.05] mx-8 md:mx-12">Landscapes</span>
				<span class="w-1 h-1 rounded-full bg-white/[0.05]"></span>
			</span>
		))}
	</div>
</div>

<section id="commission" class="relative py-24 md:py-40">
	<div class="max-w-[1400px] mx-auto px-4 md:px-8 lg:px-12">
		<!-- Section header -->
		<div class="reveal mb-16 md:mb-24">
			<div class="flex items-end justify-between">
				<div>
					<p class="text-[11px] uppercase tracking-[0.5em] text-amber-400/40 mb-4">Work with Me</p>
					<h2 class="text-4xl md:text-7xl font-bold">Commission</h2>
				</div>
			</div>
			<div class="h-[1px] bg-white/5 mt-8 line-draw"></div>
		</div>

		<div class="grid md:grid-cols-12 gap-8 md:gap-6 lg:gap-12">
			<!-- Info side -->
			<div class="md:col-span-5 order-1">
				<div class="md:sticky md:top-32 space-y-6 md:space-y-8">
					<!-- Quote -->
					<div class="reveal">
						<p class="text-2xl md:text-3xl font-['Playfair_Display',serif] italic text-white/40 leading-relaxed">
							"Every commission is a collaboration — your story, my strokes."
						</p>
					</div>

					<!-- How it works -->
					<div class="bg-white/[0.02] border border-white/[0.06] rounded-xl md:rounded-2xl p-6 md:p-8 reveal reveal-delay-1">
						<h3 class="font-['Playfair_Display',serif] text-lg md:text-xl mb-6">How it works</h3>
						<div class="space-y-6">
							{[
								{ step: '01', title: 'Request', text: 'Submit your vision with a reference photo' },
								{ step: '02', title: 'Quote', text: 'Receive pricing within 48 hours' },
								{ step: '03', title: 'Progress', text: 'WIP updates at every stage' },
								{ step: '04', title: 'Delivery', text: 'High-res digital + original shipped' },
							].map((item, i) => (
								<div class="flex gap-4 items-start group">
									<span class="text-[11px] font-['Space_Mono',monospace] text-amber-400/20 group-hover:text-amber-400/40 transition-colors pt-0.5">{item.step}</span>
									<div>
										<p class="text-sm font-medium text-white/60 mb-0.5">{item.title}</p>
										<p class="text-[12px] text-white/25 leading-relaxed">{item.text}</p>
									</div>
								</div>
							))}
						</div>
					</div>

					<!-- Pricing hint -->
					<div class="bg-white/[0.02] border border-white/[0.06] rounded-xl md:rounded-2xl p-6 md:p-8 reveal reveal-delay-2">
						<div class="flex items-center justify-between mb-4">
							<h3 class="font-['Playfair_Display',serif] text-lg md:text-xl">Starting at</h3>
							<span class="text-[10px] uppercase tracking-[0.3em] text-white/20">INR</span>
						</div>
						<div class="space-y-3">
							{[
								{ size: 'A5 — Small', price: '500' },
								{ size: 'A4 — Standard', price: '1,000' },
								{ size: 'A3 — Large', price: '2,000' },
							].map(tier => (
								<div class="flex items-center justify-between py-2 border-b border-white/[0.04] last:border-0">
									<span class="text-sm text-white/40">{tier.size}</span>
									<span class="text-sm font-['Space_Mono',monospace] text-white/30">₹{tier.price}</span>
								</div>
							))}
						</div>
						<p class="text-[10px] text-white/15 mt-4">Timeline: 1-3 weeks. Rush available.</p>
					</div>
				</div>
			</div>

			<!-- Form side -->
			<div class="md:col-span-7 order-2">
				<form class="space-y-5 md:space-y-6 reveal reveal-delay-1" id="commission-form">
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-white/25 mb-2 md:mb-3 font-['Space_Mono',monospace]">Name</label>
							<input type="text" name="name" required
								class="w-full bg-white/[0.03] border border-white/[0.08] rounded-xl px-4 md:px-5 py-3.5 md:py-4 text-sm text-white placeholder-white/15 focus:outline-none focus:border-white/20 transition-all" 
								placeholder="Your name" />
						</div>
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-white/25 mb-2 md:mb-3 font-['Space_Mono',monospace]">Email</label>
							<input type="email" name="email" required
								class="w-full bg-white/[0.03] border border-white/[0.08] rounded-xl px-4 md:px-5 py-3.5 md:py-4 text-sm text-white placeholder-white/15 focus:outline-none focus:border-white/20 transition-all"
								placeholder="you@email.com" />
						</div>
					</div>

					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-white/25 mb-2 md:mb-3 font-['Space_Mono',monospace]">Size</label>
							<select name="size"
								class="w-full bg-white/[0.03] border border-white/[0.08] rounded-xl px-4 md:px-5 py-3.5 md:py-4 text-sm text-white/50 focus:outline-none focus:border-white/20 transition-all appearance-none">
								<option value="a5">A5 — Small</option>
								<option value="a4" selected>A4 — Standard</option>
								<option value="a3">A3 — Large</option>
								<option value="custom">Custom</option>
							</select>
						</div>
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-white/25 mb-2 md:mb-3 font-['Space_Mono',monospace]">Medium</label>
							<select name="medium"
								class="w-full bg-white/[0.03] border border-white/[0.08] rounded-xl px-4 md:px-5 py-3.5 md:py-4 text-sm text-white/50 focus:outline-none focus:border-white/20 transition-all appearance-none">
								<option value="graphite" selected>Graphite Pencil</option>
								<option value="charcoal">Charcoal</option>
								<option value="mixed">Mixed Media</option>
							</select>
						</div>
					</div>

					<div>
						<label class="block text-[10px] uppercase tracking-widest text-white/25 mb-2 md:mb-3 font-['Space_Mono',monospace]">Reference Photo</label>
						<label for="file-upload" class="block border-2 border-dashed border-white/[0.08] rounded-xl p-6 md:p-10 text-center cursor-pointer hover:border-white/15 transition-all group">
							<input type="file" id="file-upload" name="reference" accept="image/*" class="hidden" />
							<div class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-white/10 flex items-center justify-center mx-auto mb-3 group-hover:border-white/20 transition-colors">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
							</div>
							<p class="text-white/20 text-xs">Drop or click to upload</p>
							<p class="text-white/10 text-[10px] mt-1 font-['Space_Mono',monospace]">JPG, PNG up to 10MB</p>
						</label>
					</div>

					<div>
						<label class="block text-[10px] uppercase tracking-widest text-white/25 mb-2 md:mb-3 font-['Space_Mono',monospace]">Details</label>
						<textarea name="details" rows="4"
							class="w-full bg-white/[0.03] border border-white/[0.08] rounded-xl px-4 md:px-5 py-3.5 md:py-4 text-sm text-white placeholder-white/15 focus:outline-none focus:border-white/20 transition-all resize-none"
							placeholder="Tell me about your vision — subject, mood, style..."></textarea>
					</div>

					<button type="submit"
						class="magnetic-btn w-full bg-amber-400 text-[#0a0a0a] rounded-full py-4 md:py-5 text-[11px] uppercase tracking-[0.25em] font-medium hover:bg-amber-300 transition-all">
						Submit Request
					</button>
					<p class="text-center text-[10px] text-white/15 font-['Space_Mono',monospace]">Usually responds within 24-48 hours</p>
				</form>
			</div>
		</div>
	</div>
</section>
